{
  "name": "pomo-electron",
  "version": "1.5.1",
  "description": "A Pomodoro timer with a work-hours budget, cycle visualization, and flexible pause controls.",
  "author": "David Hamm",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dist:portable": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "dist:installer": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "pack": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "release:patch:build": "node scripts/release.js patch --build",
    "release:minor:build": "node scripts/release.js minor --build",
    "release:major:build": "node scripts/release.js major --build"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^42.6.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.davidhamm.pomoelectron",
    "productName": "Pomo Electron",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "!**/*.md",
      "CHANGELOG.md"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "PomoElectron-${version}-portable.exe"
    }
  }
}
